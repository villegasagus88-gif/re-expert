# ════════════════════════════════════════════════════════════════════
# RE Expert Backend — Environment Variables
# ════════════════════════════════════════════════════════════════════
# Local dev:  copiar a `backend/.env` y completar valores.
# Railway:    pegar todo (excluyendo placeholders) en Variables tab.
# NUNCA commitear .env real al repo.
# ════════════════════════════════════════════════════════════════════


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REQUERIDAS — sin estas el backend no arranca
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Claude API key. Sin saldo no funciona el chat (resto de la app sí).
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL via Supabase Pooler (transaction mode, port 6543).
#
# FORMATO OBLIGATORIO:
#   - Driver: postgresql+asyncpg://  (NO postgresql://)
#   - User:   postgres.<project-ref>  (con el . y el ref)
#   - Host:   aws-1-us-east-1.pooler.supabase.com (verificar región)
#   - Port:   6543 (transaction pooler, NO 5432)
#
# Get it from: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql+asyncpg://postgres.uaiiqjouxlcvleiimokz:<DB_PASSWORD>@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Secret para firmar JWTs (access + refresh tokens). Mínimo 32 chars.
# Generar con: openssl rand -hex 32
# Cambiarlo invalida TODOS los JWTs en circulación (logout global).
JWT_SECRET=your-jwt-secret-here

# Emails con acceso admin (gestión del knowledge base), separados por coma.
# Ej: ADMIN_EMAILS=mati@re-expert.app,agustin@re-expert.app
# Vacío = nadie es admin → los endpoints /api/knowledge quedan bloqueados (fail-safe).
ADMIN_EMAILS=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SUPABASE — para Storage (knowledge base, reports)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Project URL. Sin esto, /api/knowledge/files devuelve [] (degrade limpio).
SUPABASE_URL=https://uaiiqjouxlcvleiimokz.supabase.co

# service_role key (BYPASS RLS — mantener SECRET).
# Get it from: Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CORS / Frontend
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# URL pública del frontend. REQUIRED cuando DEBUG=false (sino CORS bloquea todo).
# Prod:    https://re-expert.netlify.app  (o tu dominio custom)
# Staging: https://staging.re-expert.app
# Dev:     dejar vacío (localhost auto-incluido cuando DEBUG=true)
FRONTEND_URL=https://re-expert.netlify.app

# Origins extras (JSON list). Solo para casos especiales (CDN preview, etc).
# CORS_ORIGINS=["https://preview-cdn.example.com"]


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM PROVIDER selector
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# auto: usa Gemini si hay GEMINI_API_KEY, sino Anthropic.
# anthropic: forzar Claude.
# gemini: forzar Gemini.
LLM_PROVIDER=auto

# Modelo Claude. Default = alias sin fecha (siempre apunta al último estable).
# Pinear a snapshot con fecha si querés determinismo: claude-sonnet-4-6-YYYYMMDD
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini key — fallback gratis 15 RPM / 1M tok/día.
# Create at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AGENT / SOL — scheduler + canales de notificación
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# URL pública del backend — usada por SOL para construir links absolutos
# a PDFs generados que manda por WhatsApp/Telegram al usuario.
# En Railway: la URL del servicio. En local: http://localhost:8000.
BACKEND_PUBLIC_URL=https://re-expert-production.up.railway.app

# Habilita el poller que dispara recordatorios. Apagar en tests.
SCHEDULER_ENABLED=true
SCHEDULER_POLL_INTERVAL_SECONDS=30
# SCHEDULER_BATCH_SIZE=50

# Telegram bot (opcional — sin esto el canal Telegram queda off, resto anda)
# Bot: crear con @BotFather, copiar el token.
# ⚠️ TELEGRAM_WEBHOOK_SECRET es OBLIGATORIO en producción (DEBUG=false): sin
#    él, el webhook rechaza TODO con 503 (fail-closed, incluye el pairing).
#    Cualquier string aleatorio largo; cargarlo junto con el token.
# TELEGRAM_AGENT_ENABLED: el agente SOL por mensaje libre de Telegram.
#    Default false (decisión 2026-07-04): pairing y avisos salientes andan
#    igual; el chat conversacional por Telegram se prende con true.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=re_expert_bot
# TELEGRAM_WEBHOOK_BASE_URL=https://re-expert-production.up.railway.app
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_AGENT_ENABLED=false

# Twilio / WhatsApp Business (opcional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Google Maps (opcional — para SOL optimizando rutas de visita)
# GOOGLE_MAPS_API_KEY=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EMAIL — Resend para forgot-password (opcional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Sin RESEND_API_KEY, los emails de reset solo se loggean (DEV) o
# no se envían (PROD). Free tier Resend = 3000 emails/mes.
# Get it from: https://resend.com/api-keys
RESEND_API_KEY=
# El dominio del FROM tiene que estar verificado en Resend.
RESEND_FROM=RE Expert <hola@re-expert.app>


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MERCADO PAGO — billing en ARS (suscripciones). Reemplaza a Stripe en AR.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Mientras MP_ACCESS_TOKEN + MP_PLAN_ID estén vacíos, el módulo de MP es
# INERTE (el backend se comporta como antes). Cuando estén seteados:
#   - El registro pide tarjeta upfront (el usuario nuevo arranca "inactive").
#   - /api/billing/checkout crea la suscripción en MP (redirige al init_point).
#   - Webhook a configurar en MP → POST {BACKEND}/api/billing/mp/webhook
#
# Crear el plan (con trial de 7 días) y sacar credenciales en:
#   https://www.mercadopago.com.ar/developers/panel
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# Secreto de firma del webhook (Panel MP → Webhooks). Sin esto, en PROD el
# webhook rechaza todo (evita que forjen "suscripción autorizada").
MP_WEBHOOK_SECRET=
# id del preapproval_plan (el plan mensual de $69.900 con 7 días de prueba).
MP_PLAN_ID=
# URL de retorno post-checkout (opcional). Default: FRONTEND_URL/app.html
MP_BACK_URL=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STRIPE — billing legacy (reemplazado por Mercado Pago; dejar vacío)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_...). Sin esto, en PROD el webhook
# rechaza todo (CRÍTICO — evita que atacantes forjen checkout.completed).
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# Price ID del plan Pro. Get from: https://dashboard.stripe.com/products
STRIPE_PRICE_ID_PRO=

# URLs post-checkout (deben ser absolutas, HTTPS en prod)
STRIPE_SUCCESS_URL=https://re-expert.netlify.app/success.html
STRIPE_CANCEL_URL=https://re-expert.netlify.app/pricing.html


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MONITORING — Sentry (opcional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Sentry DSN — leave empty to disable Sentry.
# Get it from: https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Performance sampling [0.0–1.0]. 0.0 = errors only.
# Free tier = 10k transactions/month, mantener bajo.
SENTRY_TRACES_SAMPLE_RATE=0.0


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APP knobs (defaults razonables, override solo si necesitás)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Modo debug: dev local = true, prod = false (activa HTTPS redirect + HSTS).
DEBUG=false

# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7
# APP_NAME=RE Expert API
# VERSION=0.1.0
# PORT=8000  (Railway lo setea solo)
