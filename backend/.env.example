# ============================================
# RE Expert Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ===== REQUIRED =====

# Anthropic API key for Claude AI calls.
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string (Supabase).
# Get it from: Supabase Dashboard > Project Settings > Database > Connection string > URI
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.eykyzfslnooyxynmhggf.supabase.co:5432/postgres

# JWT secret used to verify Supabase auth tokens server-side.
# Get it from: Supabase Dashboard > Project Settings > API > JWT Settings > JWT Secret
# IMPORTANT: This is different from the anon/service_role key.
JWT_SECRET=your-jwt-secret-here

# ===== OPTIONAL =====

# Stripe secret key for future payment integration (leave empty if not used yet).
# Get it from: https://dashboard.stripe.com/apikeys
STRIPE_KEY=

# ===== OPTIONAL (with sensible defaults) =====

# APP_NAME=RE Expert API
# VERSION=0.1.0
# DEBUG=false
# ANTHROPIC_MODEL=claude-sonnet-4-6-20250514
# CORS_ORIGINS=["http://localhost:8080","http://localhost:3000"]
