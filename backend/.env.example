# ============================================
# RE Expert Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ===== REQUIRED =====
# Solo DATABASE_URL y JWT_SECRET son obligatorias. El proveedor de LLM puede
# ser Gemini (free) o Anthropic — ver la sección "LLM PROVIDER" más abajo.

# PostgreSQL connection string (Supabase).
# Get it from: Supabase > Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:password@db.uaiiqjouxlcvleiimokz.supabase.co:5432/postgres

# JWT secret for signing backend access/refresh tokens (HS256).
# Use a long random string (e.g. openssl rand -hex 32).
JWT_SECRET=your-jwt-secret-here

# Supabase project URL (OPTIONAL — only needed for storage/realtime, not auth).
# Get it from: Supabase > Project Settings > API > Project URL
SUPABASE_URL=

# Supabase service_role key (OPTIONAL — KEEP SECRET if used).
# Get it from: Supabase > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# ===== STRIPE =====

# Stripe secret key (test: sk_test_..., live: sk_live_...)
# Get it from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...)
# Get it from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# Stripe Price ID for the Pro plan (price_...)
# Get it from: https://dashboard.stripe.com/products
STRIPE_PRICE_ID_PRO=

# URLs Stripe redirects to after checkout
STRIPE_SUCCESS_URL=http://localhost:8080/success.html
STRIPE_CANCEL_URL=http://localhost:8080/pricing.html

# ===== LLM PROVIDER (Gemini free O Anthropic) =====
# Selector de proveedor para el agente SOL y el chat:
#   auto (default) → usa Gemini si hay GEMINI_API_KEY, sino Anthropic.
#   gemini         → fuerza Gemini.
#   anthropic      → fuerza Claude.
# LLM_PROVIDER=auto

# Gemini (free tier). Crear key en https://aistudio.google.com/apikey
# Con esto seteado, NO hace falta ANTHROPIC_API_KEY.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (OPCIONAL — solo si LLM_PROVIDER=anthropic o no hay Gemini).
# Get it from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== OPTIONAL =====

# Server port (Railway sets this automatically)
# PORT=8000

# ===== AUTH / JWT (with sensible defaults) =====

# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7
# Vigencia del link de recuperación de contraseña (forgot-password).
# RESET_TOKEN_EXPIRE_MINUTES=30

# ===== CORS =====

# Primary frontend URL — REQUIRED in production (when DEBUG=false).
# Dev:     leave empty (localhost origins are auto-included when DEBUG=true).
# Staging: FRONTEND_URL=https://staging.re-expert.app
# Prod:    FRONTEND_URL=https://re-expert.app
FRONTEND_URL=

# Extra allowed origins (JSON list). Only needed for special cases.
# CORS_ORIGINS=["https://cdn.preview.example.com"]

# ===== AGENT / SOL ASSISTANT =====

# Habilitar el scheduler de recordatorios (background poller).
# Ponelo en false en tests automatizados.
# SCHEDULER_ENABLED=true
# SCHEDULER_POLL_INTERVAL_SECONDS=30
# SCHEDULER_BATCH_SIZE=50

# ===== TELEGRAM (opcional) =====
# Crear bot vía @BotFather en Telegram, copiar el token aquí.
# Sin esto, el canal Telegram queda deshabilitado pero el resto de SOL anda.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=re_expert_bot
# TELEGRAM_WEBHOOK_BASE_URL=https://re-expert-production.up.railway.app
# TELEGRAM_WEBHOOK_SECRET=algun-string-aleatorio-largo

# ===== TWILIO / WHATSAPP (opcional) =====
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ===== EMAIL (opcional, vía Resend) =====
# RESEND_API_KEY=
# RESEND_FROM=RE Expert <hola@re-expert.app>

# ===== MAPS (opcional) =====
# Para optimización real de rutas de visita en SOL.
# GOOGLE_MAPS_API_KEY=

# ===== OPTIONAL (with sensible defaults) =====

# APP_NAME=RE Expert API
# VERSION=0.1.0
# DEBUG=false
