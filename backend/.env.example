# ============================================
# RE Expert Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ===== REQUIRED =====

# Anthropic API key for Claude AI calls.
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string (Supabase).
# Get it from: Supabase > Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:password@db.eykyzfslnooyxynmhggf.supabase.co:5432/postgres

# JWT secret used to verify Supabase auth tokens server-side.
# Get it from: Supabase > Project Settings > API > JWT Settings > JWT Secret
JWT_SECRET=your-jwt-secret-here

# Supabase project URL.
# Get it from: Supabase > Project Settings > API > Project URL
SUPABASE_URL=https://eykyzfslnooyxynmhggf.supabase.co

# Supabase service_role key (KEEP SECRET - bypasses RLS).
# Get it from: Supabase > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ===== OPTIONAL =====

# Stripe secret key for future payment integration.
# Get it from: https://dashboard.stripe.com/apikeys
STRIPE_KEY=

# Server port (Railway sets this automatically)
# PORT=8000

# ===== OPTIONAL (with sensible defaults) =====

# APP_NAME=RE Expert API
# VERSION=0.1.0
# DEBUG=false
# ANTHROPIC_MODEL=claude-sonnet-4-6-20250514
# CORS_ORIGINS=["http://localhost:8080","http://localhost:3000"]
